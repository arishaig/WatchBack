# WatchBackNet Configuration
# Copy this file to .env and fill in your provider credentials

# Provider Selection
WATCHBACK_PROVIDER=jellyfin
WATCHBACK_TIME_MACHINE_DAYS=14

# Jellyfin Configuration
JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=your_jellyfin_api_key

# Trakt Configuration
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_USERNAME=your_trakt_username
TRAKT_ACCESS_TOKEN=your_trakt_access_token

# Bluesky Configuration (optional)
BLUESKY_HANDLE=your.bsky.social
BLUESKY_APP_PASSWORD=your_bluesky_app_password

# Reddit Configuration
# Note: Reddit authentication is handled via public PullPush API, no credentials needed

# Database Configuration (optional)
# WATCHBACK_DATABASE_PATH=/app/data/watchback.db

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
