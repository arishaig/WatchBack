# Jellyfin Configuration
JF_URL=http://localhost:8096
JF_API_KEY=your_jellyfin_api_key_here

# Trakt Configuration
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_USERNAME=your_trakt_username_here
# Optional: TRAKT_ACCESS_TOKEN=your_oauth_token_here

# Bluesky Configuration (Optional — enables authenticated search)
# BSKY_IDENTIFIER=your.handle.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Reddit Settings
REDDIT_AUTO_OPEN=1
REDDIT_MAX_THREADS=3
REDDIT_MAX_COMMENTS=250

# Webhook Security (Optional — must match Jellyfin webhook plugin header)
# WEBHOOK_SECRET=your_secret_here

# Preferences
# THEME_MODE=dark
# TIME_MACHINE_DAYS=14

# Authentication
# WATCHBACK_SECRET_KEY=  # Auto-generated if not set; persisted in CONFIG_DIR
# WATCHBACK_SECURE_COOKIES=false  # Set to true if behind HTTPS reverse proxy

# Storage
CONFIG_DIR=./config
